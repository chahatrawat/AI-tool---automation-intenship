<script>
  // Custom cursor
  const cursor = document.getElementById('cursor');
  document.addEventListener('mousemove', e => {
    cursor.style.left = e.clientX + 'px';
    cursor.style.top = e.clientY + 'px';
  });
  document.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('mouseenter', () => cursor.classList.add('big'));
    el.addEventListener('mouseleave', () => cursor.classList.remove('big'));
  });

  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 80);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));

  // AI copy generation
  async function generateCopy() {
    const loading = document.getElementById('ai-loading');
    const copyEl = document.getElementById('ai-copy');
    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          messages: [{
            role: 'user',
            content: `Write a short, punchy 3-sentence brand paragraph for VOLT., an electric scooter rental startup, an electric scooter rental startup based in Indian cities. Brand voice: bold, youthful, urban, no-fluff. Tone is like a cool city brand — not corporate. Focus on freedom, speed, and sustainability. No lists, no headers. Just 3 tight sentences that flow together. Do not start with "VOLT."`,
          }]
        })
      });
      const data = await res.json();
      const text = data.content?.[0]?.text || '';
      loading.style.display = 'none';
      copyEl.style.display = 'block';
      // Typewriter effect
      let i = 0;
      copyEl.textContent = '';
      function type() {
        if (i < text.length) {
          copyEl.textContent += text[i++];
          setTimeout(type, 18);
        }
      }
      type();
    } catch (err) {
      loading.style.display = 'none';
      copyEl.style.display = 'block';
      copyEl.textContent = 'Cities weren\'t built for traffic jams — they were built for movement. VOLT. puts an electric scooter at your fingertips wherever you are, whenever you need it. Clean, quiet, and faster than a rickshaw in peak hour.';
    }
  }

  // Trigger AI copy when features section enters view
  const aiSection = document.querySelector('.ai-section');
  let aiTriggered = false;
  const aiObserver = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting && !aiTriggered) {
      aiTriggered = true;
      generateCopy();
    }
  }, { threshold: 0.2 });
  aiObserver.observe(aiSection);
</script>

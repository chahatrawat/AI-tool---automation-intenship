    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section" id="how">
  <div class="section-tag">
    <span style="width:20px;height:1px;background:var(--volt-accent);display:inline-block"></span>
    How it works
  </div>
  <h2 class="section-title reveal">Three steps.<br>Zero friction.</h2>
  <div class="steps-grid reveal">
    <div class="step">
      <div class="step-num">01</div>
      <div class="step-icon">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <rect x="4" y="2" width="14" height="18" rx="3" stroke="#C8F000" stroke-width="1.5"/>
          <path d="M8 7h6M8 11h4" stroke="#C8F000" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="11" cy="16" r="1.5" fill="#C8F000"/>
        </svg>
      </div>
      <h3>Download & sign up</h3>
      <p>Create your account in under 60 seconds. Verify your number and you're ready to roll — no waiting, no paperwork.</p>
    </div>
    <div class="step">
      <div class="step-num">02</div>

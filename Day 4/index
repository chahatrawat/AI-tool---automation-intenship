<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Premium Neon Footer</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    min-height:100vh;
    background:#000;
    display:flex;
    align-items:flex-end;
}

/* ================= FOOTER ================= */

.footer{
    width:100%;
    padding:80px 8% 30px;
    background:
    radial-gradient(circle at top left,#1e1b4b 0%,transparent 35%),
    radial-gradient(circle at bottom right,#0ea5e9 0%,transparent 35%),
    linear-gradient(135deg,#020617,#000000,#030712);
    position:relative;
    overflow:hidden;
}

/* Animated Neon Border */

.footer::before{
    content:"";
    position:absolute;
    top:0;
    left:-100%;
    width:200%;
    height:3px;
    background:linear-gradient(
    90deg,
    transparent,
    #00e5ff,
    #7c3aed,
    #00e5ff,
    transparent);
    animation:borderMove 4s linear infinite;
    box-shadow:
    0 0 15px #00e5ff,
    0 0 30px #7c3aed;
}

@keyframes borderMove{
    100%{
        transform:translateX(50%);
    }
}

/* Grid */

.footer-grid{
    display:grid;
    grid-template-columns:2fr 1fr 1fr 1.5fr;
    gap:30px;
}

/* Glass Cards */

.card{
    background:rgba(255,255,255,.04);
    border:1px solid rgba(255,255,255,.08);
    backdrop-filter:blur(20px);
    border-radius:24px;
    padding:28px;
    transition:.4s;
}

.card:hover{
    transform:translateY(-8px);
    box-shadow:
    0 0 25px rgba(0,229,255,.2),
    0 0 40px rgba(124,58,237,.2);
}

/* Brand */

.logo{
    font-size:32px;
    font-weight:700;
    background:linear-gradient(90deg,#00e5ff,#7c3aed);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
    margin-bottom:15px;
}

.brand p{
    color:#94a3b8;
    line-height:1.8;
}

/* Titles */

.card h3{
    color:white;
    margin-bottom:25px;
    position:relative;
}

.card h3::after{
    content:'';
    position:absolute;
    left:0;
    bottom:-10px;
    width:50px;
    height:3px;
    border-radius:10px;
    background:linear-gradient(90deg,#00e5ff,#7c3aed);
}

/* Links */

ul{
    list-style:none;
}

ul li{
    margin:14px 0;
}

ul li a{
    color:#94a3b8;
    text-decoration:none;
    transition:.3s;
}

ul li a:hover{
    color:#00e5ff;
    padding-left:8px;
}

/* Social */

.social{
    display:flex;
    gap:12px;
    margin-top:25px;
}

.social a{
    width:45px;
    height:45px;
    border-radius:12px;
    background:rgba(255,255,255,.05);
    border:1px solid rgba(255,255,255,.1);
    color:white;
    text-decoration:none;
    display:flex;
    justify-content:center;
    align-items:center;
    transition:.3s;
}

.social a:hover{
    background:linear-gradient(135deg,#00e5ff,#7c3aed);
    transform:translateY(-5px);
}

/* Newsletter */

.newsletter input{
    width:100%;
    padding:14px;
    border:none;
    outline:none;
    border-radius:12px;
    margin-bottom:12px;
    background:rgba(255,255,255,.06);
    color:white;
}

.newsletter button{
    width:100%;
    padding:14px;
    border:none;
    cursor:pointer;
    border-radius:12px;
    color:white;
    font-weight:600;
    background:linear-gradient(
    135deg,
    #00e5ff,
    #7c3aed);
}

.newsletter button:hover{
    box-shadow:
    0 0 20px #00e5ff,
    0 0 30px #7c3aed;
}

/* Bottom */

.footer-bottom{
    margin-top:50px;
    padding-top:25px;
    border-top:1px solid rgba(255,255,255,.08);
    text-align:center;
    color:#94a3b8;
}

/* Responsive */

@media(max-width:1000px){

.footer-grid{
    grid-template-columns:1fr 1fr;
}

}

@media(max-width:700px){

.footer-grid{
    grid-template-columns:1fr;
}

.card{
    text-align:center;
}

.card h3::after{
    left:50%;
    transform:translateX(-50%);
}

.social{
    justify-content:center;
}

}

</style>
</head>
<body>

<footer class="footer">

<div class="footer-grid">

    <!-- Brand -->

    <div class="card brand">
        <div class="logo">NovaTech</div>

        <p>
            Building next-generation digital experiences
            with innovative technology and creative design.
        </p>

        <div class="social">
            <a href="#">FB</a>
            <a href="#">IG</a>
            <a href="#">X</a>
            <a href="#">IN</a>
        </div>
    </div>

    <!-- Links -->

    <div class="card">
        <h3>Quick Links</h3>

        <ul>
            <li><a href="#">Home</a></li>
            <li><a href="#">Services</a></li>
            <li><a href="#">Projects</a></li>
            <li><a href="#">About</a></li>
            <li><a href="#">Contact</a></li>
        </ul>
    </div>

    <!-- Support -->

    <div class="card">
        <h3>Support</h3>

        <ul>
            <li><a href="#">Help Center</a></li>
            <li><a href="#">FAQ</a></li>
            <li><a href="#">Documentation</a></li>
            <li><a href="#">Privacy</a></li>
            <li><a href="#">Terms</a></li>
        </ul>
    </div>

    <!-- Newsletter -->

    <div class="card newsletter">
        <h3>Newsletter</h3>

        <input
        type="email"
        placeholder="Enter Email"
        required>

        <button>
            Subscribe Now
        </button>
    </div>

</div>

<div class="footer-bottom">
    © 2026 NovaTech. All Rights Reserved.
</div>

</footer>

</body>
</html>